  <qti-item-body>
    <qti-choice-interaction max-choices="1" response-identifier="RESPONSE">
      <qti-prompt data-catalog-idref="tts_prompt">
        <p>What is conflict in a narrative?</p>
      </qti-prompt>
      <qti-simple-choice fixed="true" identifier="A">
        <div data-catalog-idref="tts_choice_A">
          <p>The setting of the story</p>
        </div>
        <qti-feedback-block identifier="feedback_A" outcome-identifier="FEEDBACK" show-hide="show">
          <qti-content-body>
            <div class="tb-feedback-incorrect" data-catalog-idref="feedback_A">
              <p>The setting is where and when the story happens — not the problem driving it.</p>
            </div>
          </qti-content-body>
        </qti-feedback-block>
      </qti-simple-choice>
      <qti-simple-choice fixed="true" identifier="B">
        <div data-catalog-idref="tts_choice_B">
          <p>The list of characters</p>
        </div>
        <qti-feedback-block identifier="feedback_B" outcome-identifier="FEEDBACK" show-hide="show">
          <qti-content-body>
            <div class="tb-feedback-incorrect" data-catalog-idref="feedback_B">
              <p>Characters experience the conflict — the conflict itself is the problem they're up against.</p>
            </div>
          </qti-content-body>
        </qti-feedback-block>
      </qti-simple-choice>
      <qti-simple-choice fixed="true" identifier="C">
        <div data-catalog-idref="tts_choice_C">
          <p>The final sentence of the story</p>
        </div>
        <qti-feedback-block identifier="feedback_C" outcome-identifier="FEEDBACK" show-hide="show">
          <qti-content-body>
            <div class="tb-feedback-incorrect" data-catalog-idref="feedback_C">
              <p>Conflict drives the whole story from the start — it isn't a closing line.</p>
            </div>
          </qti-content-body>
        </qti-feedback-block>
      </qti-simple-choice>
      <qti-simple-choice fixed="true" identifier="D">
        <div data-catalog-idref="tts_choice_D">
          <p>The problem the characters struggle against, driving the plot</p>
        </div>
        <qti-feedback-block identifier="feedback_D" outcome-identifier="FEEDBACK" show-hide="show">
          <qti-content-body>
            <div class="tb-feedback-correct" data-catalog-idref="feedback_D">
              <p>Correct! Conflict is the central problem characters struggle against, and it drives the plot.</p>
            </div>
          </qti-content-body>
        </qti-feedback-block>
      </qti-simple-choice>
    </qti-choice-interaction>
